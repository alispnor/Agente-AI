# Obrigatório
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Servidor (npm run dev / npm start). Se 3000 estiver ocupada, use outra, ex.: 3001
PORT=3000

# Docker Compose: porta no teu PC (mapeamento host → 3000 no container). Predefinido 3001.
AGENTS_AI_HOST_PORT=3001

# Docker: caminho base dos seus projetos (montado em /mnt/projects)
PROJECT_PATH=/home/seu-usuario/projetos
